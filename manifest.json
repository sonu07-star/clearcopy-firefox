{
  "manifest_version": 3,
  "name": "ClearCopy - Clean Links",
  "version": "1.0.0",
  "description": "Remove tracking parameters and copy clean, shareable links in one click.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "storage"
  ],
  "background": {
    "scripts": [
      "cleaner.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "ClearCopy",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon.svg"
    }
  },
  "commands": {
    "copy-clean-link": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Copy a clean link for the current page"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "clearcopy@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
